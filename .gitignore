# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
server.log

# env files — ignore real secrets, but allow the committed example template
.env.local
.env.production
.env.development
.env.staging
.env
# Allow the example template to be committed:
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
