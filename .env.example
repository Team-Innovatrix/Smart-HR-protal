# ============================================================
# Smart HR Portal — Environment Variables Template
# ============================================================
# Copy this file to .env.local for local development.
# For production, set these values directly in Vercel's
# Environment Variables dashboard (Settings > Environment Variables).
#
# DEV  = used in local development only
# PROD = must be set for production deployments
# BOTH = required in both environments
# ============================================================

# ---------------------------
# Database — MongoDB  [BOTH]
# ---------------------------
MONGODB_URI=your_mongodb_uri_here
# DEV example:  mongodb://localhost:27017/hr
# PROD example: mongodb+srv://<user>:<pass>@cluster.mongodb.net/hr?retryWrites=true&w=majority
MONGODB_DB_NAME=hr

# ---------------------------
# Clerk Authentication  [BOTH]
# ---------------------------
# DEV:  use sk_test_* / pk_test_* keys from your Clerk Test instance
# PROD: use sk_live_* / pk_live_* keys from your Clerk Production instance
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Clerk routing URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk webhook secret (from Clerk Dashboard > Webhooks)  [BOTH]
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret_here

# ---------------------------
# Environment  [BOTH]
# ---------------------------
# Set to "development" locally; Vercel sets "production" automatically.
NODE_ENV=development

# ---------------------------
# OpenAI  [BOTH]
# ---------------------------
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# ---------------------------
# AWS S3 (file uploads)  [BOTH]
# ---------------------------
AWS_S3_BUCKET_NAME=your_bucket_name
AWS_S3_REGION=us-east-2
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ---------------------------
# App URLs  [BOTH]
# ---------------------------
# DEV:
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# PROD (update to your production domain):
# NEXT_PUBLIC_APP_URL=https://portal.tielo.io
# NEXT_PUBLIC_BASE_URL=https://portal.tielo.io

# ---------------------------
# Upstash Redis  [BOTH]
# ---------------------------
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ---------------------------
# SendGrid Email  [BOTH]
# ---------------------------
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=no-reply@yourdomain.com

# ---------------------------
# Feature Flags  [BOTH]
# ---------------------------
NEXT_PUBLIC_VOICE_COMMANDS_ENABLED=true
# PROD only: set to 'true' to suppress console logs in production
# DISABLE_PRODUCTION_LOGS=false
